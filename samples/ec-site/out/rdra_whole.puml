@startuml
!theme plain

actor "Administrator" as Admin
actor "Customer" as Customer

usecase "Add to Cart" as AddToCart
usecase "Authorize Payment" as AuthorizePayment
usecase "Cancel Order" as Cancel
usecase "Capture Payment" as Capture
usecase "Confirm Order Details" as ConfirmOrder
usecase "Enter Payment Information" as InputPaymentInfo
usecase "Place Order" as PlaceOrder
usecase "Refund Payment" as RefundPayment
usecase "Remove from Cart" as RemoveCartItem
usecase "Search Products" as SearchProducts
usecase "Select Shipping Address" as SelectAddress
usecase "Change Cart Item Quantity" as UpdateCartItem
usecase "View Cart" as ViewCart
usecase "View Order History" as ViewOrderHistory
usecase "View Product Details" as ViewProduct

rectangle "Add Products to Cart" as BucCart
rectangle "Process Order" as BucOrder
rectangle "Make Payment" as BucPayment

package "Commerce System" as CommerceSystem

component "Payment Gateway" as PaymentGW
component "Shipping Service" as ShippingSvc

database "Cart" as Cart
database "Cart Item" as CartItem
database "Category" as Category
database "Customer Account" as CustomerAccount
database "Order" as Order
database "Order Line" as OrderLine
database "Payment" as Payment
database "Product" as Product
database "Shipping Address" as ShippingAddress

boundary "Address Selection Screen" as AddressSelectScreen
boundary "Cart Screen" as CartScreen
boundary "Order Complete Screen" as OrderCompleteScreen
boundary "Order Confirmation Screen" as OrderConfirmScreen
boundary "Order History Screen" as OrderHistoryScreen
boundary "Payment Information Screen" as PaymentInputScreen
boundary "Payment Result Screen" as PaymentResultScreen
boundary "Product Detail Screen" as ProductDetailScreen
boundary "Product Search Screen" as ProductSearchScreen

control "Cancel Order" as Cancel
control "Capture Payment" as Capture
control "Confirm Delivery" as Deliver
control "Start Shipping" as Ship

collections "Cancelled" as Cancelled
collections "Delivered" as Delivered
collections "Payment Completed" as Paid
collections "Order Received" as Pending
collections "Shipped" as Shipped

Customer --> BucPayment
Customer --> BucOrder
Customer --> BucCart
Customer --> PaymentGW
BucPayment ..> EcShopping : belongs
BucPayment ..> InputPaymentInfo : contains
BucPayment ..> AuthorizePayment : contains
BucPayment ..> Capture : contains
BucPayment ..> RefundPayment : contains
BucOrder ..> EcShopping : belongs
BucOrder ..> SelectAddress : contains
BucOrder ..> ConfirmOrder : contains
BucOrder ..> PlaceOrder : contains
BucOrder ..> ViewOrderHistory : contains
BucOrder ..> Cancel : contains
BucCart ..> EcShopping : belongs
BucCart ..> SearchProducts : contains
BucCart ..> ViewProduct : contains
BucCart ..> AddToCart : contains
BucCart ..> UpdateCartItem : contains
BucCart ..> RemoveCartItem : contains
BucCart ..> ViewCart : contains
Product -- Category
ShippingAddress -- CustomerAccount
Cart -- CustomerAccount
CartItem -- Product
CartItem -- Cart
Order -- CustomerAccount
Order -- ShippingAddress
OrderLine -- Product
OrderLine -- Order
Payment -- Order
SearchProducts ..> ProductSearchScreen : displays
ViewProduct ..> ProductDetailScreen : displays
AddToCart ..> CartScreen : displays
UpdateCartItem ..> CartScreen : displays
RemoveCartItem ..> CartScreen : displays
ViewCart ..> CartScreen : displays
InputPaymentInfo ..> PaymentInputScreen : displays
AuthorizePayment ..> PaymentResultScreen : displays
Capture ..> Capture : raises
Capture ..> PaymentResultScreen : displays
RefundPayment ..> PaymentResultScreen : displays
SelectAddress ..> AddressSelectScreen : displays
ConfirmOrder ..> OrderConfirmScreen : displays
PlaceOrder ..> OrderCompleteScreen : displays
ViewOrderHistory ..> OrderHistoryScreen : displays
Cancel ..> Cancel : raises
Cancel ..> OrderHistoryScreen : displays
@enduml
