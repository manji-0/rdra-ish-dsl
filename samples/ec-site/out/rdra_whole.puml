@startuml
!theme plain

actor "管理者" as Admin
actor "購入者" as Customer

usecase "カートに追加する" as AddToCart
usecase "決済を承認する" as AuthorizePayment
usecase "注文をキャンセルする" as CancelOrder
usecase "決済を確定する" as CapturePayment
usecase "注文内容を確認する" as ConfirmOrder
usecase "決済情報を入力する" as InputPaymentInfo
usecase "注文を確定する" as PlaceOrder
usecase "返金する" as RefundPayment
usecase "カートから削除する" as RemoveCartItem
usecase "商品を検索する" as SearchProducts
usecase "配送先を選択する" as SelectAddress
usecase "カートの数量を変更する" as UpdateCartItem
usecase "カートを確認する" as ViewCart
usecase "注文履歴を見る" as ViewOrderHistory
usecase "商品詳細を見る" as ViewProduct

rectangle "商品を買い物籠に入れる" as BucCart
rectangle "注文を処理する" as BucOrder
rectangle "決済を行う" as BucPayment

component "決済ゲートウェイ" as PaymentGW
component "配送サービス" as ShippingSvc

database "カート" as Cart
database "カートアイテム" as CartItem
database "カテゴリ" as Category
database "顧客アカウント" as CustomerAccount
database "注文" as Order
database "注文明細" as OrderLine
database "決済" as Payment
database "商品" as Product
database "配送先住所" as ShippingAddress

boundary "配送先選択画面" as AddressSelectScreen
boundary "カート画面" as CartScreen
boundary "注文完了画面" as OrderCompleteScreen
boundary "注文確認画面" as OrderConfirmScreen
boundary "注文履歴画面" as OrderHistoryScreen
boundary "決済情報入力画面" as PaymentInputScreen
boundary "決済結果画面" as PaymentResultScreen
boundary "商品詳細画面" as ProductDetailScreen
boundary "商品検索画面" as ProductSearchScreen

control "キャンセル申請" as CancelRequested
control "配達確認" as DeliveryConfirmed
control "決済確定" as PaymentCaptured
control "発送開始" as ShipmentStarted

collections "キャンセル" as OrderCancelled
collections "配達完了" as OrderDelivered
collections "決済完了" as OrderPaid
collections "注文受付" as OrderPending
collections "発送済" as OrderShipped

Customer --> BucPayment
Customer --> BucOrder
Customer --> BucCart
Customer --> PaymentGW
BucPayment ..> EcShopping : belongs
BucPayment ..> InputPaymentInfo : contains
BucPayment ..> AuthorizePayment : contains
BucPayment ..> CapturePayment : contains
BucPayment ..> RefundPayment : contains
BucOrder ..> EcShopping : belongs
BucOrder ..> SelectAddress : contains
BucOrder ..> ConfirmOrder : contains
BucOrder ..> PlaceOrder : contains
BucOrder ..> ViewOrderHistory : contains
BucOrder ..> CancelOrder : contains
BucCart ..> EcShopping : belongs
BucCart ..> SearchProducts : contains
BucCart ..> ViewProduct : contains
BucCart ..> AddToCart : contains
BucCart ..> UpdateCartItem : contains
BucCart ..> RemoveCartItem : contains
BucCart ..> ViewCart : contains
Product -- Category
ShippingAddress -- CustomerAccount
Cart -- CustomerAccount
CartItem -- Product
CartItem -- Cart
Order -- CustomerAccount
Order -- ShippingAddress
OrderLine -- Product
OrderLine -- Order
Payment -- Order
PaymentCaptured ..> OrderPending : raises
ShipmentStarted ..> OrderPaid : raises
DeliveryConfirmed ..> OrderShipped : raises
CancelRequested ..> OrderPending : raises
SearchProducts ..> Category : reads
SearchProducts ..> Product : reads
SearchProducts ..> ProductSearchScreen : displays
ViewProduct ..> Product : reads
ViewProduct ..> ProductDetailScreen : displays
AddToCart ..> Product : reads
AddToCart ..> Cart : updates
AddToCart ..> CartItem : creates
AddToCart ..> CartScreen : displays
UpdateCartItem ..> CartItem : updates
UpdateCartItem ..> CartScreen : displays
RemoveCartItem ..> CartItem : deletes
RemoveCartItem ..> CartScreen : displays
ViewCart ..> Product : reads
ViewCart ..> Cart : reads
ViewCart ..> CartItem : reads
ViewCart ..> CartScreen : displays
InputPaymentInfo ..> Order : reads
InputPaymentInfo ..> Payment : creates
InputPaymentInfo ..> PaymentInputScreen : displays
AuthorizePayment ..> Payment : updates
AuthorizePayment ..> PaymentResultScreen : displays
CapturePayment ..> Order : updates
CapturePayment ..> Payment : updates
CapturePayment ..> PaymentCaptured : raises
CapturePayment ..> PaymentResultScreen : displays
RefundPayment ..> Order : updates
RefundPayment ..> Payment : updates
RefundPayment ..> PaymentResultScreen : displays
SelectAddress ..> ShippingAddress : reads
SelectAddress ..> AddressSelectScreen : displays
ConfirmOrder ..> ShippingAddress : reads
ConfirmOrder ..> Cart : reads
ConfirmOrder ..> CartItem : reads
ConfirmOrder ..> OrderConfirmScreen : displays
PlaceOrder ..> Cart : updates
PlaceOrder ..> Order : creates
PlaceOrder ..> OrderLine : creates
PlaceOrder ..> OrderCompleteScreen : displays
ViewOrderHistory ..> Order : reads
ViewOrderHistory ..> OrderLine : reads
ViewOrderHistory ..> OrderHistoryScreen : displays
CancelOrder ..> Order : updates
CancelOrder ..> CancelRequested : raises
CancelOrder ..> OrderHistoryScreen : displays
@enduml
