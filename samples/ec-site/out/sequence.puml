@startuml
!theme plain

actor "Customer" as Customer
control "Add To Cart API" as AddToCartApi
control "Cancel Order API" as CancelOrderApi
control "Payment Authorization API" as PaymentAuthorizationApi
control "Payment Capture API" as PaymentCaptureApi
control "Payment Input API" as PaymentInputApi
control "Payment Refund API" as PaymentRefundApi
control "Place Order API" as PlaceOrderApi
control "Remove Cart Item API" as RemoveCartItemApi
control "Update Cart Item API" as UpdateCartItemApi
database "Cart" as Cart
database "Cart Item" as CartItem
database "Order" as Order
database "Order Line" as OrderLine
database "Payment" as Payment
boundary "Cart Screen" as CartScreen
boundary "Order Complete Screen" as OrderCompleteScreen
boundary "Order History Screen" as OrderHistoryScreen
boundary "Payment Information Screen" as PaymentInputScreen
boundary "Payment Result Screen" as PaymentResultScreen

== Add to Cart ==
Customer -> CartScreen : Add to Cart
CartScreen -> AddToCartApi : Add to Cart
activate AddToCartApi
group transaction (API atomic boundary)
AddToCartApi -> Cart : update
AddToCartApi -> CartItem : create
end
AddToCartApi --> CartScreen : Cart Screen
CartScreen --> Customer : Cart Screen
deactivate AddToCartApi

== Authorize Payment ==
Customer -> PaymentResultScreen : Authorize Payment
PaymentResultScreen -> PaymentAuthorizationApi : Authorize Payment
activate PaymentAuthorizationApi
PaymentAuthorizationApi -> Payment : update
PaymentAuthorizationApi --> PaymentResultScreen : Payment Result Screen
PaymentResultScreen --> Customer : Payment Result Screen
deactivate PaymentAuthorizationApi

== Cancel Order ==
Customer -> OrderHistoryScreen : Cancel Order
OrderHistoryScreen -> CancelOrderApi : Cancel Order
activate CancelOrderApi
CancelOrderApi -> Order : update
CancelOrderApi --> OrderHistoryScreen : Order History Screen
OrderHistoryScreen --> Customer : Order History Screen
deactivate CancelOrderApi

== Capture Payment ==
Customer -> PaymentResultScreen : Capture Payment
PaymentResultScreen -> PaymentCaptureApi : Capture Payment
activate PaymentCaptureApi
group transaction (API atomic boundary)
PaymentCaptureApi -> Order : update
PaymentCaptureApi -> Payment : update
end
PaymentCaptureApi --> PaymentResultScreen : Payment Result Screen
PaymentResultScreen --> Customer : Payment Result Screen
deactivate PaymentCaptureApi

== Enter Payment Information ==
Customer -> PaymentInputScreen : Enter Payment Information
PaymentInputScreen -> PaymentInputApi : Enter Payment Information
activate PaymentInputApi
PaymentInputApi -> Payment : create
PaymentInputApi --> PaymentInputScreen : Payment Information Screen
PaymentInputScreen --> Customer : Payment Information Screen
deactivate PaymentInputApi

== Place Order ==
Customer -> OrderCompleteScreen : Place Order
OrderCompleteScreen -> PlaceOrderApi : Place Order
activate PlaceOrderApi
group transaction (API atomic boundary)
PlaceOrderApi -> Cart : update
PlaceOrderApi -> Order : create
PlaceOrderApi -> OrderLine : create
end
PlaceOrderApi --> OrderCompleteScreen : Order Complete Screen
OrderCompleteScreen --> Customer : Order Complete Screen
deactivate PlaceOrderApi

== Refund Payment ==
Customer -> PaymentResultScreen : Refund Payment
PaymentResultScreen -> PaymentRefundApi : Refund Payment
activate PaymentRefundApi
group transaction (API atomic boundary)
PaymentRefundApi -> Order : update
PaymentRefundApi -> Payment : update
end
PaymentRefundApi --> PaymentResultScreen : Payment Result Screen
PaymentResultScreen --> Customer : Payment Result Screen
deactivate PaymentRefundApi

== Remove from Cart ==
Customer -> CartScreen : Remove from Cart
CartScreen -> RemoveCartItemApi : Remove from Cart
activate RemoveCartItemApi
RemoveCartItemApi -> CartItem : delete
RemoveCartItemApi --> CartScreen : Cart Screen
CartScreen --> Customer : Cart Screen
deactivate RemoveCartItemApi

== Change Cart Item Quantity ==
Customer -> CartScreen : Change Cart Item Quantity
CartScreen -> UpdateCartItemApi : Change Cart Item Quantity
activate UpdateCartItemApi
UpdateCartItemApi -> CartItem : update
UpdateCartItemApi --> CartScreen : Cart Screen
CartScreen --> Customer : Cart Screen
deactivate UpdateCartItemApi

@enduml
