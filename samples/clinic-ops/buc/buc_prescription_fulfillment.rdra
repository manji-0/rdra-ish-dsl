module buc.prescription_fulfillment

import shared.actors
import shared.entities
import shared.biz

buc BucPrescriptionFulfillment "Fulfill Prescriptions"

usecase SearchMedication     "Search Medication"
usecase DraftPrescription    "Draft Prescription"
usecase SendPrescription     "Send Prescription"
usecase ConfirmDispense      "Confirm Dispense"
usecase CancelPrescription   "Cancel Prescription"
usecase RefillPrescription   "Refill Prescription"

screen MedicationSearchScreen "Medication Search Screen"
screen PrescriptionScreen     "Prescription Screen"
screen PharmacyStatusScreen   "Pharmacy Status Screen"

api MedicationCatalogApi "Medication Catalog API"
api DraftPrescriptionApi  "Draft Prescription API"
api SendPrescriptionApi   "Send Prescription API"
api ConfirmDispenseApi    "Confirm Dispense API"
api RefillPrescriptionApi "Refill Prescription API"

performs(Clinician, BucPrescriptionFulfillment)
performs(Nurse, BucPrescriptionFulfillment)
belongs(BucPrescriptionFulfillment, CareDelivery)

contains(BucPrescriptionFulfillment, SearchMedication)
contains(BucPrescriptionFulfillment, DraftPrescription)
contains(BucPrescriptionFulfillment, SendPrescription)
contains(BucPrescriptionFulfillment, ConfirmDispense)
contains(BucPrescriptionFulfillment, CancelPrescription)
contains(BucPrescriptionFulfillment, RefillPrescription)
contains(ClinicOpsSystem, MedicationCatalogApi)
contains(ClinicOpsSystem, DraftPrescriptionApi)
contains(ClinicOpsSystem, SendPrescriptionApi)
contains(ClinicOpsSystem, ConfirmDispenseApi)
contains(ClinicOpsSystem, RefillPrescriptionApi)

uses(Clinician, PharmacyNetwork)

displays(SearchMedication, MedicationSearchScreen)
invokes(SearchMedication, MedicationCatalogApi)
reads(MedicationCatalogApi, Medication)
shows(MedicationSearchScreen, Medication)

displays(DraftPrescription, PrescriptionScreen)
invokes(DraftPrescription, DraftPrescriptionApi)
reads(DraftPrescriptionApi, Encounter)
creates(DraftPrescriptionApi, Prescription)

displays(SendPrescription, PrescriptionScreen)
invokes(SendPrescription, SendPrescriptionApi)
updates(SendPrescriptionApi, Prescription)
raises(SendPrescription, EvPrescriptionSent)

displays(ConfirmDispense, PharmacyStatusScreen)
invokes(ConfirmDispense, ConfirmDispenseApi)
updates(ConfirmDispenseApi, Prescription)
raises(ConfirmDispense, EvPrescriptionDispensed)

displays(CancelPrescription, PrescriptionScreen)
updates(CancelPrescription, Prescription)
raises(CancelPrescription, EvPrescriptionCancelled)

displays(RefillPrescription, PrescriptionScreen)
invokes(RefillPrescription, RefillPrescriptionApi)
creates(RefillPrescriptionApi, Prescription)
reads(RefillPrescriptionApi, Medication)
