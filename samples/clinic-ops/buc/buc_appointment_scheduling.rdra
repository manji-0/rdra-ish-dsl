module buc.appointment_scheduling

import shared.actors
import shared.entities
import shared.biz

buc BucAppointmentScheduling "Schedule Appointments" description "Find, reserve, book, change, and notify appointment slots."

usecase SearchAvailability     "Search Availability"
usecase ReserveAppointment     "Reserve Appointment"
usecase BookAppointment        "Book Appointment"
usecase RescheduleAppointment  "Reschedule Appointment"
usecase CancelAppointment      "Cancel Appointment"
usecase MarkNoShow             "Mark No Show"
usecase SendAppointmentNotice  "Send Appointment Notice"

screen ScheduleSearchScreen "Schedule Search Screen"
screen AppointmentScreen    "Appointment Screen"
screen AppointmentNoticeScreen "Appointment Notice Screen"

api SearchAvailabilityApi    "Search Availability API"
api ReserveAppointmentApi    "Reserve Appointment API"
api BookAppointmentApi       "Book Appointment API"
api RescheduleAppointmentApi "Reschedule Appointment API"
api CancelAppointmentApi     "Cancel Appointment API"
api AppointmentNoticeApi     "Appointment Notice API"

performs(FrontDesk, BucAppointmentScheduling)
performs(Patient, BucAppointmentScheduling)
performs(FrontDesk, SearchAvailability)
performs(Patient, SearchAvailability)
performs(FrontDesk, ReserveAppointment)
performs(Patient, ReserveAppointment)
performs(FrontDesk, BookAppointment)
performs(Patient, BookAppointment)
performs(FrontDesk, RescheduleAppointment)
performs(Patient, RescheduleAppointment)
performs(FrontDesk, CancelAppointment)
performs(Patient, CancelAppointment)
performs(FrontDesk, MarkNoShow)
performs(FrontDesk, SendAppointmentNotice)
belongs(BucAppointmentScheduling, PatientAccess)
  .when(PatientRequestWindow)
  .where(FrontDeskCounter)
  .where(PatientPortal)
  .by(FrontDeskTerminal)
  .by(PatientMobile)
contains(BucAppointmentScheduling, SearchAvailability)
contains(BucAppointmentScheduling, ReserveAppointment)
contains(BucAppointmentScheduling, BookAppointment)
contains(BucAppointmentScheduling, RescheduleAppointment)
contains(BucAppointmentScheduling, CancelAppointment)
contains(BucAppointmentScheduling, MarkNoShow)
contains(BucAppointmentScheduling, SendAppointmentNotice)
contains(ClinicOpsSystem, SearchAvailabilityApi)
contains(ClinicOpsSystem, ReserveAppointmentApi)
contains(ClinicOpsSystem, BookAppointmentApi)
contains(ClinicOpsSystem, RescheduleAppointmentApi)
contains(ClinicOpsSystem, CancelAppointmentApi)
contains(ClinicOpsSystem, AppointmentNoticeApi)

uses(Patient, MessagingGateway)

displays(SearchAvailability, ScheduleSearchScreen)
invokes(SearchAvailability, SearchAvailabilityApi)
reads(SearchAvailabilityApi, ProviderSchedule)
reads(SearchAvailabilityApi, Provider)
reads(SearchAvailabilityApi, ClinicLocation)
shows(ScheduleSearchScreen, ProviderSchedule)
requires_permission(SearchAvailability, ScheduleRead)
requires_medium(SearchAvailability, FrontDeskTerminal)
requires_medium(SearchAvailability, PatientMobile)
requires_permission(SearchAvailabilityApi, ScheduleRead)

displays(ReserveAppointment, AppointmentScreen)
invokes(ReserveAppointment, ReserveAppointmentApi)
creates(ReserveAppointmentApi, Appointment)
updates(ReserveAppointmentApi, ProviderSchedule)
requires_permission(ReserveAppointment, ScheduleWrite)
requires_medium(ReserveAppointment, FrontDeskTerminal)
requires_medium(ReserveAppointment, PatientMobile)
requires_permission(ReserveAppointmentApi, ScheduleWrite)

displays(BookAppointment, AppointmentScreen)
invokes(BookAppointment, BookAppointmentApi)
updates(BookAppointmentApi, Appointment)
updates(BookAppointmentApi, ProviderSchedule)
raises(BookAppointment, EvAppointmentScheduled)
requires_permission(BookAppointment, ScheduleWrite)
requires_medium(BookAppointment, FrontDeskTerminal)
requires_medium(BookAppointment, PatientMobile)
requires_permission(BookAppointmentApi, ScheduleWrite)

displays(RescheduleAppointment, AppointmentScreen)
invokes(RescheduleAppointment, RescheduleAppointmentApi)
updates(RescheduleAppointmentApi, Appointment)
updates(RescheduleAppointmentApi, ProviderSchedule)
raises(RescheduleAppointment, EvAppointmentRescheduled)
requires_permission(RescheduleAppointment, ScheduleWrite)
requires_medium(RescheduleAppointment, FrontDeskTerminal)
requires_medium(RescheduleAppointment, PatientMobile)
requires_permission(RescheduleAppointmentApi, ScheduleWrite)

displays(CancelAppointment, AppointmentScreen)
invokes(CancelAppointment, CancelAppointmentApi)
updates(CancelAppointmentApi, Appointment)
updates(CancelAppointmentApi, ProviderSchedule)
raises(CancelAppointment, EvAppointmentCancelled)
requires_permission(CancelAppointment, ScheduleWrite)
requires_medium(CancelAppointment, FrontDeskTerminal)
requires_medium(CancelAppointment, PatientMobile)
requires_permission(CancelAppointmentApi, ScheduleWrite)

displays(MarkNoShow, AppointmentScreen)
updates(MarkNoShow, Appointment)
raises(MarkNoShow, EvAppointmentNoShow)
requires_permission(MarkNoShow, ScheduleWrite)
requires_medium(MarkNoShow, FrontDeskTerminal)

displays(SendAppointmentNotice, AppointmentNoticeScreen)
invokes(SendAppointmentNotice, AppointmentNoticeApi)
creates(AppointmentNoticeApi, Notification)
creates(AppointmentNoticeApi, PatientMessage)
requires_permission(SendAppointmentNotice, ScheduleRead)
requires_medium(SendAppointmentNotice, FrontDeskTerminal)
sets(SendAppointmentNotice, Notification, "status", "notifdelivered")
sets(SendAppointmentNotice, Notification, "delivered_at", "timestamptz")
sets(SendAppointmentNotice, PatientMessage, "status", "msgsent")
sets(SendAppointmentNotice, PatientMessage, "sent_at", "timestamptz")
triggers(EvAppointmentScheduled, SendAppointmentNotice)
triggers(EvAppointmentRescheduled, SendAppointmentNotice)
triggers(EvAppointmentCancelled, SendAppointmentNotice)
