module buc.billing_claims

import shared.actors
import shared.entities
import shared.biz

buc BucBillingClaims "Bill and Collect Claims"

usecase CreateCharge        "Create Charge"
usecase GenerateClaim       "Generate Claim"
usecase SubmitClaim         "Submit Claim"
usecase ReceiveClaimAccepted "Receive Claim Accepted"
usecase RecordClaimDenial   "Record Claim Denial"
usecase PostPayment         "Post Payment"
usecase ReconcileBalance    "Reconcile Balance"
usecase VoidCharge          "Void Charge"

screen ChargeWorklistScreen "Charge Worklist Screen"
screen ClaimScreen          "Claim Screen"
screen PaymentPostingScreen "Payment Posting Screen"
screen BalanceScreen        "Balance Screen"

api CreateChargeApi      "Create Charge API"
api GenerateClaimApi     "Generate Claim API"
api SubmitClaimApi       "Submit Claim API"
api PaymentPostApi       "Payment Posting API"
api BalanceApi           "Balance API"

performs(BillingSpecialist, BucBillingClaims)
belongs(BucBillingClaims, RevenueCycle)

contains(BucBillingClaims, CreateCharge)
contains(BucBillingClaims, GenerateClaim)
contains(BucBillingClaims, SubmitClaim)
contains(BucBillingClaims, ReceiveClaimAccepted)
contains(BucBillingClaims, RecordClaimDenial)
contains(BucBillingClaims, PostPayment)
contains(BucBillingClaims, ReconcileBalance)
contains(BucBillingClaims, VoidCharge)
contains(ClinicOpsSystem, CreateChargeApi)
contains(ClinicOpsSystem, GenerateClaimApi)
contains(ClinicOpsSystem, SubmitClaimApi)
contains(ClinicOpsSystem, PaymentPostApi)
contains(ClinicOpsSystem, BalanceApi)

uses(BillingSpecialist, PaymentGateway)

displays(CreateCharge, ChargeWorklistScreen)
invokes(CreateCharge, CreateChargeApi)
creates(CreateChargeApi, Charge)
updates(CreateChargeApi, AccountBalance)
reads(CreateChargeApi, Encounter)
sets(CreateCharge, Charge, "status", "chargeposted")
sets(CreateCharge, Charge, "posted_at", "timestamptz")
triggers(EvEncounterSigned, BucBillingClaims)
triggers(EvEncounterSigned, CreateCharge)

displays(GenerateClaim, ClaimScreen)
invokes(GenerateClaim, GenerateClaimApi)
creates(GenerateClaimApi, Claim)
updates(GenerateClaimApi, Charge)
reads(GenerateClaimApi, InsurancePolicy)

displays(SubmitClaim, ClaimScreen)
invokes(SubmitClaim, SubmitClaimApi)
updates(SubmitClaimApi, Claim)
raises(SubmitClaim, EvClaimSubmitted)

displays(ReceiveClaimAccepted, ClaimScreen)
updates(ReceiveClaimAccepted, Claim)
raises(ReceiveClaimAccepted, EvClaimAccepted)

displays(RecordClaimDenial, ClaimScreen)
updates(RecordClaimDenial, Claim)
raises(RecordClaimDenial, EvClaimDenied)

displays(PostPayment, PaymentPostingScreen)
invokes(PostPayment, PaymentPostApi)
creates(PaymentPostApi, PaymentTransaction)
updates(PaymentPostApi, Claim)
raises(PostPayment, EvClaimPaid)
sets(PostPayment, PaymentTransaction, "status", "payposted")
sets(PostPayment, PaymentTransaction, "processed_at", "timestamptz")

displays(ReconcileBalance, BalanceScreen)
invokes(ReconcileBalance, BalanceApi)
updates(BalanceApi, AccountBalance)
reads(BalanceApi, PaymentTransaction)
sets(ReconcileBalance, AccountBalance, "is_closed", "true")
sets(ReconcileBalance, AccountBalance, "closed_at", "timestamptz")

displays(VoidCharge, ChargeWorklistScreen)
updates(VoidCharge, Charge)
sets(VoidCharge, Charge, "status", "chargevoided")

// Access constraints
requires_permission(CreateCharge, BillingClaimWrite)
requires_medium(CreateCharge, BillingWorkstation)
requires_permission(CreateChargeApi, BillingClaimWrite)

requires_permission(GenerateClaim, BillingClaimWrite)
requires_medium(GenerateClaim, BillingWorkstation)
requires_permission(GenerateClaimApi, BillingClaimWrite)

requires_permission(SubmitClaim, BillingClaimWrite)
requires_medium(SubmitClaim, BillingWorkstation)
requires_permission(SubmitClaimApi, BillingClaimWrite)

requires_permission(ReceiveClaimAccepted, BillingClaimWrite)
requires_medium(ReceiveClaimAccepted, BillingWorkstation)

requires_permission(RecordClaimDenial, BillingClaimWrite)
requires_medium(RecordClaimDenial, BillingWorkstation)

requires_permission(PostPayment, PaymentPost)
requires_medium(PostPayment, BillingWorkstation)
requires_permission(PaymentPostApi, PaymentPost)

requires_permission(ReconcileBalance, PaymentPost)
requires_medium(ReconcileBalance, BillingWorkstation)
requires_permission(BalanceApi, PaymentPost)

requires_permission(VoidCharge, BillingClaimWrite)
requires_medium(VoidCharge, BillingWorkstation)
