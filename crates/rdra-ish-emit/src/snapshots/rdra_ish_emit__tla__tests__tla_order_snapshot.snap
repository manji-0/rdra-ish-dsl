---- MODULE RdraSpec ----
\* Generated by rdra-ish. Do not edit manually.

VARIABLES Order_status, Order_delivered_at

vars == <<Order_status, Order_delivered_at>>

TypeOK ==
  /\ Order_status \in {"pending", "paid", "shipped", "delivered", "cancelled"}
  /\ Order_delivered_at \in {"null", "present"}

Init ==
  /\ Order_status = "pending"
  /\ Order_delivered_at = "null"

\* EvCapture: pending -> paid
Order_EvCapture_pending_to_paid ==
  /\ Order_status = "pending"
  /\ Order_status' = "paid"
  /\ UNCHANGED Order_delivered_at

\* EvShip: paid -> shipped
Order_EvShip_paid_to_shipped ==
  /\ Order_status = "paid"
  /\ Order_status' = "shipped"
  /\ UNCHANGED Order_delivered_at

\* EvDeliver: shipped -> delivered
Order_EvDeliver_shipped_to_delivered ==
  /\ Order_status = "shipped"
  /\ Order_status' = "delivered"
  /\ Order_delivered_at' = "present"

\* EvCancel: pending -> cancelled
Order_EvCancel_pending_to_cancelled ==
  /\ Order_status = "pending"
  /\ Order_status' = "cancelled"
  /\ UNCHANGED Order_delivered_at

Next ==
  \/ Order_EvCapture_pending_to_paid
  \/ Order_EvShip_paid_to_shipped
  \/ Order_EvDeliver_shipped_to_delivered
  \/ Order_EvCancel_pending_to_cancelled

Spec == Init /\ [][Next]_vars /\ WF_vars(Next)

Inv_Order_0 == (Order_status = "delivered") => (Order_delivered_at = "present")
Forbidden_Order_0 == ~(Order_status = "cancelled" /\ Order_delivered_at = "present")

Safety ==
  /\ TypeOK
  /\ Inv_Order_0
  /\ Forbidden_Order_0

PaidLeadsToShipped == (Order_status = "paid") ~> (Order_status = "shipped")
EventuallyTerminal == <>((Order_status = "delivered") \/ (Order_status = "cancelled"))
AfterAssert_DeliverOrder_0 == [][(Order_EvDeliver_shipped_to_delivered) => (Order_status' = "delivered") /\ (Order_EvDeliver_shipped_to_delivered) => (Order_delivered_at' = "present")]_vars

THEOREM Spec => []Safety
